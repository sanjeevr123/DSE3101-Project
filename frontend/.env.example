# Copy this file to .env and fill in your OneMap credentials.
# Register at https://www.onemap.gov.sg/apidocs/ to get an account.

ONEMAP_API_EMAIL=your_email@example.com
ONEMAP_API_PASSWORD=your_password
# ONEMAP_TOKEN=  # Optional: pre-fetched token. If left blank, the app auto-fetches one using the credentials above.
